{
  "name": "anything-llm",
  "version": "1.0.0",
  "description": "A full-stack application that lets you turn any document into a queryable database using LLMs",
  "private": true,
  "workspaces": [
    "frontend",
    "server",
    "collector"
  ],
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server": "cd server && nodemon index.js",
    "dev:frontend": "cd frontend && vite",
    "dev:collector": "cd collector && nodemon index.js",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev:frontend\" \"npm run dev:collector\"",
    "setup": "npm install && cd server && npm install && cd ../frontend && npm install && cd ../collector && npm install",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "prisma:generate": "cd server && npx prisma generate",
    "prisma:migrate": "cd server && npx prisma migrate dev",
    "prisma:studio": "cd server && npx prisma studio"
  },
  "keywords": [
    "llm",
    "ai",
    "document-qa",
    "vector-database",
    "openai",
    "chatbot"
  ],
  "author": "Mintplex Labs",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.0",
    "eslint": "^8.45.0",
    "jest": "^29.6.1",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
